# Local-dev configuration for the kiosk BFF. Copy and edit:
#
#   cp .env.example .env
#   set -a; . ./.env; set +a        # export every var into the shell
#   make build && ./bin/kiosk       # serves SPA + API on :8080
#
# The Go server reads plain env vars (no .env auto-loading — keeps it
# stdlib-only). For frontend hot-reload run `npm --prefix web run dev` in
# another shell; Vite proxies /api to :8080.
#
# Point these at real homelab services (e.g. via Tailscale / port-forward)
# or leave the optional ones unset — every integration degrades to a
# friendly "unavailable" tile rather than failing.

# --- required ---
KIOSK_ADDR=:8080
KIOSK_PROM_URL=http://prometheus.example.lan

# --- reads (optional) ---
KIOSK_KUMA_BASE_URL=http://uptime-kuma.example.lan:3001
KIOSK_KUMA_SLUG=homelab

# --- actions (optional; set KIOSK_ALLOW_ACTIONS=false for a read-only screen) ---
KIOSK_ALLOW_ACTIONS=true

KIOSK_SAB_URL=http://sabnzbd.example.lan:8080
KIOSK_SAB_APIKEY=changeme

KIOSK_QBT_NAMES=se
KIOSK_QBT_SE_URL=http://qbittorrent.example.lan:8080
KIOSK_QBT_SE_USER=admin
KIOSK_QBT_SE_PASS=changeme
KIOSK_QBT_FREELEECH_CAT=freeleech

KIOSK_PIHOLE_URL=http://10.10.53.53
KIOSK_PIHOLE_PASSWORD=changeme
KIOSK_PIHOLE_DISABLE_SECONDS=300
